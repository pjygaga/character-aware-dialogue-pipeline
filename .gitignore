# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.env
.env.local

# Jupyter
.ipynb_checkpoints/

# Heavy weight files blocked by extension
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
**/checkpoints/

# Whitelist: ship the small LoRA adapter (~21 MB) directly in the repo
!models/hermione_lora_adapter/adapter_model.safetensors

# BERT classifier weights (~440 MB) stay blocked; users either retrain
# (models/emotion_classifier_v2/train_classifier.py) or drop their own
# checkpoint at models/emotion_classifier_v2/model.safetensors.

# Training-run logs (keep the summary CSVs/PNGs in outputs/, skip raw logs)
outputs/classifier/v1/
outputs/classifier/v2/
outputs/classifier/dropout_*/

# Training artifact logs (keep summary CSVs/PNGs but skip raw logs)
wandb/
runs/
**/logs/
*.log

# IDE
.vscode/
.idea/

# Windows / macOS system files
Thumbs.db
Desktop.ini
.DS_Store

# API keys and secrets
*.key
secrets.json

# Downloaded zips (results of packaging)
*.zip


.claude/